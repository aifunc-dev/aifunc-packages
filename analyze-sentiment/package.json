{
  "type": "standalone",
  "name": "analyze-sentiment",
  "displayName": "Sentiment Analysis",
  "description": "Analyze the sentiment of input text with customizable labels (zero-shot classification).",
  "version": "1.0.0",
  "engine": "^0.2.0",
  "author": {
    "name": "GildenEye"
  },
  "license": "MIT",
  "categories": ["text", "classification", "nlp"],
  "tags": ["sentiment", "emotion", "classification", "zero-shot"],
  "output": {
    "repair": true,
    "retry": {
      "maxAttempts": 3,
      "on": ["invalid_json", "schema_mismatch", "timeout"]
    }
  }
}

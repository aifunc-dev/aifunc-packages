{
  "type": "standalone",
  "name": "extract-entities",
  "displayName": "Entity Extraction",
  "description": "Extract named entities (people, places, organizations, dates, etc.) from text.",
  "version": "1.0.0",
  "engine": "^0.1.0",
  "author": {
    "name": "GildenEye"
  },
  "license": "MIT",
  "categories": ["text", "nlp", "extraction"],
  "tags": ["ner", "entity", "extraction", "nlp"],
  "output": {
    "repair": true,
    "retry": {
      "maxAttempts": 3,
      "on": ["invalid_json", "schema_mismatch", "timeout"]
    }
  }
}

{
  "version": "1.0.0",
  "name": "recognize-intent",
  "description": "Recognize user intent from conversational text with confidence scores.",
  "input": {
    "type": "object",
    "properties": {
      "text": {
        "type": "string",
        "description": "The user message to recognize intent from.",
        "minLength": 1
      },
      "intents": {
        "type": "array",
        "description": "List of candidate intents to recognize from.",
        "items": {
          "type": "string",
          "minLength": 1
        },
        "minItems": 2
      },
      "context": {
        "type": "string",
        "description": "Optional conversation context or system description to improve recognition accuracy."
      }
    },
    "required": ["text", "intents"],
    "additionalProperties": false
  },
  "output": {
    "type": "object",
    "properties": {
      "intent": {
        "type": "string",
        "description": "The highest-confidence recognized intent."
      },
      "confidence": {
        "type": "number",
        "description": "Confidence score of the top intent, between 0 and 1.",
        "minimum": 0,
        "maximum": 1
      },
      "rankings": {
        "type": "array",
        "description": "All intents ranked by confidence (highest first).",
        "items": {
          "type": "object",
          "properties": {
            "intent": {
              "type": "string",
              "description": "Intent label."
            },
            "confidence": {
              "type": "number",
              "description": "Confidence score between 0 and 1.",
              "minimum": 0,
              "maximum": 1
            }
          },
          "required": ["intent", "confidence"],
          "additionalProperties": false
        }
      }
    },
    "required": ["intent", "confidence", "rankings"],
    "additionalProperties": false
  },
  "errors": [
    { "code": "INVALID_INPUT", "message": "Input does not conform to the schema." },
    { "code": "OUTPUT_SCHEMA_MISMATCH", "message": "Model output does not conform to the schema." },
    { "code": "MODEL_UNAVAILABLE", "message": "Model is unavailable." },
    { "code": "TIMEOUT", "message": "Request timed out." }
  ]
}

{
  "schemaVersion": "0.1.0",
  "rules": [
    {
      "match": {
        "pattern": ".*"
      },
      "params": {
        "temperature": 0.1,
        "topP": 0.9,
        "maxTokens": 700
      }
    },
    {
      "match": {
        "models": ["gpt-4o-mini", "gpt-4o"]
      },
      "params": {
        "temperature": 0,
        "maxTokens": 650
      },
      "providerParams": {
        "openai": {
          "reasoningEffort": "low"
        }
      },
      "modelParams": {
        "gpt-4o": {
          "modalities": ["text"]
        }
      }
    }
  ]
}
